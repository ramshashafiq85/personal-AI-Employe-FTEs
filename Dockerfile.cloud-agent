# Cloud Agent Dockerfile
FROM python:3.13-slim

WORKDIR /app

# Install git and other system dependencies
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY *.py ./

# Create necessary directories
RUN mkdir -p /vault/Needs_Action /vault/Plans /vault/Pending_Approval \
    /vault/Approved /vault/Rejected /vault/Done /vault/Logs /vault/Briefings \
    /vault/Updates /vault/Signals /vault/Inbox /vault/DropFolder

# Health check
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD python -c "print('healthy')" || exit 1

# Run cloud agent
CMD ["python", "cloud_agent.py"]
